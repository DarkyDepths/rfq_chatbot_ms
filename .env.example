# Database
DATABASE_URL=postgresql+psycopg2://rfq_chatbot_user:changeme@localhost:5434/rfq_chatbot_db

# Application
APP_ENV=development
APP_DEBUG=false
APP_PORT=8003

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-nano
AZURE_OPENAI_INTENT_DEPLOYMENT=
AZURE_OPENAI_TIMEOUT_SECONDS=30.0

# Downstream services
MANAGER_BASE_URL=http://localhost:8000
INTELLIGENCE_BASE_URL=http://localhost:8002
MANAGER_REQUEST_TIMEOUT_SECONDS=10.0
INTELLIGENCE_REQUEST_TIMEOUT_SECONDS=10.0
IAM_SERVICE_URL=http://localhost:8004

# Auth bypass
AUTH_BYPASS_ENABLED=false
AUTH_BYPASS_USER_ID=v1-demo-user
AUTH_BYPASS_USER_NAME=System
AUTH_BYPASS_ROLE=estimation_dept_lead
AUTH_BYPASS_DEBUG_HEADERS_ENABLED=false
