    {
      "name": "6 - Scenario 6: Graceful degradation (manual manager outage pre-step)",
      "description": "Manual pre-step: stop rfq_manager_ms before running the turn below. This validates retrieval-independent greeting still returns 200 under stage-resolution failure. Restart manager after this folder completes.",
      "item": [
        {
          "name": "Create RFQ session for degradation check",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"rfq\",\n  \"user_id\": \"{{user_degrade}}\",\n  \"rfq_id\": \"{{golden_rfq_id_stage_a}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{chatbot_base}}/sessions"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Degradation session created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('s6_session_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Greeting turn under manager outage",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"{{question_greeting}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{chatbot_base}}/sessions/{{s6_session_id}}/turn",
            "description": "With manager stopped, this request should still return 200 for retrieval-independent content."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Greeting under outage still returns 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const marker = pm.collectionVariables.get('marker_text');",
                  "pm.test('No confidence marker in outage greeting', () => pm.expect(body.content || '').to.not.include(marker));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
