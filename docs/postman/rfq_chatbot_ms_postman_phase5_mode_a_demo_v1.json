                }
              }
            },
            "url": "{{chatbot_base}}/sessions/{{s2_stage_b_session_id}}/turn"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Stage-B turn status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const aContent = pm.collectionVariables.get('s2_stage_a_content') || '';",
                  "pm.test('Stage-B turn has source refs', () => pm.expect((body.source_refs || []).length).to.be.greaterThan(0));",
                  "pm.test('Stage contrast yields different response framing', () => pm.expect(body.content || '').to.not.eql(aContent));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
