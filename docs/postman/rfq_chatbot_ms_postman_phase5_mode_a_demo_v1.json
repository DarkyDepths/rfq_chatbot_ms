                  "pm.test('Pattern marker is absent on deterministic response', () => pm.expect(body.content || '').to.not.include(marker));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4 - Scenario 4: Capability-status honest absence",
      "item": [
        {
          "name": "Create global session for absence scenario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"global\",\n  \"user_id\": \"{{user_absence}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{chatbot_base}}/sessions"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Absence session created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('s4_session_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Ask unsupported capability",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"{{question_absence}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{chatbot_base}}/sessions/{{s4_session_id}}/turn"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Absence turn status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Absence response follows template prefix', () => pm.expect(body.content || '').to.include('I don\'t have grounded facts for'));",
                  "pm.test('Absence response includes a reason clause', () => pm.expect(body.content || '').to.include('because'));",
                  "pm.test('No retrieval source refs for capability-status path', () => pm.expect((body.source_refs || []).length).to.eql(0));"
                ]
              }
            }
          ]
        }
      ]
    },
