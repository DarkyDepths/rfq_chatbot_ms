                  "pm.test('Stage-A turn has source refs', () => pm.expect((body.source_refs || []).length).to.be.greaterThan(0));",
                  "pm.collectionVariables.set('s2_stage_a_content', body.content || '');"
                ]
              }
            }
          ]
        },
        {
          "name": "Stage-B turn (compare)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"{{question_stage}}\"\n}",
              "options": {
