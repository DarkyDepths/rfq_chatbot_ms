                "exec": [
                  "pm.test('Turn returns 200 even on retrieval failure', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Grounding-gap response should be absence-framed', () => pm.expect((body.content || '').toLowerCase()).to.include('cannot retrieve'));",
