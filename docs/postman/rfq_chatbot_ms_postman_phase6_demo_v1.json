  "item": [
    {
      "name": "0 - Bootstrap",
      "item": [
        {
          "name": "Health + initialize run users",
          "request": {
            "method": "GET",
            "url": "{{health_url}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health endpoint returns 200', () => pm.response.to.have.status(200));",
                  "const suffix = pm.collectionVariables.get('run_suffix');",
                  "const prefix = pm.collectionVariables.get('user_prefix');",
                  "pm.collectionVariables.set('user_s1', `${prefix}-s1-${suffix}`);",
                  "pm.collectionVariables.set('user_s2', `${prefix}-s2-${suffix}`);",
                  "pm.collectionVariables.set('user_s3', `${prefix}-s3-${suffix}`);",
                  "pm.collectionVariables.set('user_s4', `${prefix}-s4-${suffix}`);",
                  "pm.collectionVariables.set('user_s5', `${prefix}-s5-${suffix}`);",
                  "pm.collectionVariables.set('user_s6', `${prefix}-s6-${suffix}`);",
                  "pm.collectionVariables.set('user_s7', `${prefix}-s7-${suffix}`);",
                  "pm.collectionVariables.set('user_s8', `${prefix}-s8-${suffix}`);",
                  "pm.collectionVariables.set('user_s9', `${prefix}-s9-${suffix}`);",
                  "pm.collectionVariables.set('user_s10', `${prefix}-s10-${suffix}`);",
                  "pm.collectionVariables.set('user_s11', `${prefix}-s11-${suffix}`);",
                  "pm.collectionVariables.set('user_s12', `${prefix}-s12-${suffix}`);",
                  "pm.collectionVariables.set('user_s14', `${prefix}-s14-${suffix}`);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1 - Scenario 1: Intent rfq_specific on bound session",
      "item": [
        {
          "name": "Create RFQ session (bound)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"rfq\",\n  \"user_id\": \"{{user_s1}}\",\n  \"rfq_id\": \"{{golden_rfq_id_primary}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{chatbot_base}}/sessions"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Session created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('s1_session_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Ask deadline question",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"{{question_deadline}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{chatbot_base}}/sessions/{{s1_session_id}}/turn"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Turn returns 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Source refs are present for rfq_specific', () => pm.expect((body.source_refs || []).length).to.be.greaterThan(0));",
                  "pm.test('Assistant response is non-empty', () => pm.expect((body.content || '').trim().length).to.be.greaterThan(0));"
                ]
              }
            }
          ]
        }
      ]
    },
